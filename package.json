{
  "name": "amongus",
  "version": "1.0.0",
  "scripts": {
    "start":   "node src/app.js",
    "dev":     "nodemon src/app.js",
    "test":    "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "express":  "^4.18.2",
    "socket.io": "^4.6.1",
    "openai":   "^4.20.0",
    "uuid":     "^9.0.0",
    "dotenv":   "^16.3.1"
  },
  "devDependencies": {
    "jest":            "^29.7.0",
    "nodemon":         "^3.0.1",
    "socket.io-client": "^4.6.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.test.js"]
  }
}